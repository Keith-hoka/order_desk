# Frontend configuration for the review UI. Copy to .env.local.

# The API base is the FastAPI review service (Phase 4/7 backend).
API_BASE=http://localhost:8000

# Auth.js session secret. Generate: openssl rand -base64 32
AUTH_SECRET=

# The backend's JWT secret -- the UI server mints short-lived API tokens with
# the signed-in user's org scope. Server-side only: never NEXT_PUBLIC_.
JWT_SECRET=

# Where the UI's user accounts live (SQLite).
USERS_DB_PATH=./users.db

# Demo accounts (seeded on first run, org-demo -- sees the Phase 7 queue):
#   demo-admin@order-desk.test / demo1234
#   demo-reviewer@order-desk.test / demo1234
