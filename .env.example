# order_desk extraction service configuration.
# Copy to .env and fill in. .env is gitignored.

# --- vLLM+LoRA backend (remote Modal endpoint serving the fine-tuned adapter) ---
ADAPTER_MODEL=qwen3-4b-sft-full-r8
VLLM_BASE_URL=https://<your-modal-app>--order-desk-vllm-qwen3-4b-adapter.modal.run/v1
VLLM_API_KEY=<the vLLM endpoint key>

# --- Auth (REQUIRED in production; unset disables auth for local dev only) ---
# Generate a strong secret, at least 32 bytes: openssl rand -hex 32
JWT_SECRET=<32+ byte secret>

# --- Rate limiting (unset REDIS_URL disables it; compose sets it for you) ---
REDIS_URL=redis://redis:6379
RATE_LIMIT_PER_MINUTE=60

# --- Observability (optional; all three unset => no-op tracer) ---
# Langfuse Cloud: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Live extraction from the review UI (optional) ---
# Routing runs on OpenAI; extraction runs on the vLLM endpoint above.
OPENAI_API_KEY=

# --- Mailbox pull (optional; the UI's "Extract from mailbox" panel) ---
# The UI only takes the address; these credentials do the connecting.
# For Gmail use an app password, not the account password.
IMAP_HOST=
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
